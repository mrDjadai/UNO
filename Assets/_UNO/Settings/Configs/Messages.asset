  Message:
    _serializedList:
    - Key: NotUno
      Value: "\u0423 \u0438\u0433\u0440\u043E\u043A\u0430 \u0431\u043E\u043B\u044C\u0448\u0435
        1 \u043A\u0430\u0440\u0442\u044B"
    - Key: UnoSaid
      Value: "\u0418\u0433\u0440\u043E\u043A \u0443\u0436\u0435 \u0441\u043A\u0430\u0437\u0430\u043B
        \"\u0423\u043D\u043E\""
    - Key: UnoSafe
      Value: "\u0418\u0433\u0440\u043E\u043A \u0435\u0449\u0451 \u043C\u043E\u0436\u0435\u0442
        \u0443\u0441\u043F\u0435\u0442\u044C \u0441\u043A\u0430\u0437\u0430\u0442\u044C"
    - Key: Uno
      Value: "\u0423\u043D\u043E"
    - Key: OtherTurn
      Value: "\u0421\u0435\u0439\u0447\u0430\u0441 \u043D\u0435 \u0432\u0430\u0448
        \u0445\u043E\u0434"
    - Key: CantDrawCard
      Value: "\u0412\u044B \u0443\u0436\u0435 \u0431\u0440\u0430\u043B\u0438 \u043A\u0430\u0440\u0442\u0443"
    - Key: CanUseAnyCard
      Value: "\u0423 \u0432\u0430\u0441 \u0438\u0442\u0430\u043A \u0435\u0441\u0442\u044C,
        \u0447\u0435\u043C \u0445\u043E\u0434\u0438\u0442\u044C"
    - Key: IncorrectCard
      Value: "\u042D\u0442\u043E\u0439 \u043A\u0430\u0440\u0442\u043E\u0439 \u043D\u0435\u043B\u044C\u0437\u044F
        \u043F\u043E\u0445\u043E\u0434\u0438\u0442\u044C"
    - Key: SkipTurn
      Value: "\u0425\u043E\u0434 \u043F\u0440\u043E\u043F\u0443\u0449\u0435\u043D"
